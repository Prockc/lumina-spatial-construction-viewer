# Lumina Spatial Construction Viewer — build-time configuration.
# Copy to `.env` for local development; set the same keys as environment
# variables in the Amplify console for deployed builds.

# Base URL of the S3 bucket that hosts the .lcc2 captures (no trailing slash).
VITE_S3_BUCKET_URL=https://lumina-spatial-models.s3.us-east-1.amazonaws.com

# XGrids developer app key. Licenses the LCC-Web-SDK and removes the XGrids
# GL watermark. Obtain one at https://developer.xgrids.com
VITE_XGRIDS_APP_KEY=

# Optional: model to load when the URL has no ?model= parameter.
VITE_DEFAULT_MODEL=
